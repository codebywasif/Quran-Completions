# ----------------------------------------------------------------------------
# Quran Competition — environment configuration
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ----------------------------------------------------------------------------

NODE_ENV=development

# --- API server ---
API_PORT=3000
# Comma-separated list of allowed dashboard origins for CORS
WEB_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
# Local dev (running api outside Docker): use localhost.
# Inside docker-compose this is overridden to use host `db`.
POSTGRES_USER=quran
POSTGRES_PASSWORD=quran
POSTGRES_DB=quran
POSTGRES_PORT=5432
DATABASE_URL=postgresql://quran:quran@localhost:5432/quran?schema=public

# --- Dashboard auth (single moderator) ---
# JWT signing secret — generate a long random string for production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
# Either set a plaintext password here (hashed at boot)...
ADMIN_PASSWORD=change-me
# ...or precompute a bcrypt hash and set this instead (takes precedence).
ADMIN_PASSWORD_HASH=

# --- Timezone for the scheduler & deadline display ---
# IANA tz name. The group's primary region is the UK.
APP_TIMEZONE=Europe/London

# --- WhatsApp (whatsapp-web.js) ---
# Folder where the LocalAuth session is persisted (mount as a volume in Docker).
WA_SESSION_PATH=./.wwebjs_auth
# (Advanced) Pin a specific WhatsApp Web build to stabilise poll-vote
# decryption. Leave BLANK to use the library's tested default (recommended to
# start). To pin, pick a build that exists in the wppconnect wa-version repo and
# set BOTH variables to the same version, e.g.:
#   WA_WEB_VERSION=2.3000.10xxxxxxx
#   WA_WEB_VERSION_CACHE_URL=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.10xxxxxxx.html
# NOTE: WhatsApp expires old builds, so a stale pin will fail to load — revisit
# periodically. See README "WhatsApp reliability & safety".
WA_WEB_VERSION=
WA_WEB_VERSION_CACHE_URL=
# Path to a Chromium/Chrome executable. Leave blank to use the bundled one
# (set to /usr/bin/chromium in the Docker image).
PUPPETEER_EXECUTABLE_PATH=
